# Contact form (Resend) — copy this file to .env.local for local dev,
# and add the same variables in Vercel → Project → Settings → Environment Variables.

# Your Resend API key — create one free at https://resend.com (API Keys).
RESEND_API_KEY=

# Where contact-form enquiries are delivered (your inbox).
CONTACT_TO=hello@apextechnologies.com.au

# The "from" address. Until you verify your own domain in Resend, leave this
# unset to use Resend's sandbox sender. Once verified, e.g.:
# CONTACT_FROM=Apex Technologies <noreply@apextechnologies.com.au>
CONTACT_FROM=
